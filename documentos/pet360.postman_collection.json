    {
      "name": "Casos de teste — erros esperados",
      "item": [
        {
          "name": "401 — sem token",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{baseUrl}}/api/pets" }
        },
        {
          "name": "400 — payload inválido (peso negativo, nome vazio)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/pets",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"\",\n  \"especie\": \"CACHORRO\",\n  \"peso\": -5.0,\n  \"tutorId\": \"{{tutorId}}\"\n}"
            }
          }
        },
        {
          "name": "400 — CPF duplicado",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/tutores",
